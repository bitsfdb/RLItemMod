{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VelocityRL",
  "version": "1.1.0",
  "identifier": "com.velocityrl.app",
  "build": {
    "frontendDist": "../ui",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "echo dev",
    "beforeBuildCommand": "echo build"
  },
  "app": {
    "windows": [
      {
        "title": "VelocityRL",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../python/rl_asset_swapper.py",
      "../python/rl_injector.py",
      "../python/rl_memory_patcher.py",
      "../python/rl_upk_editor.py",
      "../python/items.json",
      "../python/keys.txt"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWSpu3p8GFkH782nQIgwgBagG4ZXlNOV8nR6rj5ekdEx+xoY76tnrThq",
      "endpoints": [
        "https://github.com/bitsfdb/RLItemMod/releases/latest/download/latest.json"
      ]
    }
  }
}
